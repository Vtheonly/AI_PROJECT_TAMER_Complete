# TAMER OCR - Fixed .gitignore
# ===========================

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
env/
ENV/
.env
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/

# OS artifacts
.DS_Store
Thumbs.db

# TAMER Specific - Ignore large data and model weights
# We ignore the directories, but NOT the specific .json extension 
# to ensure tokenizer.json can be tracked.
data/
checkpoints/
logs/
outputs/

# Re-include specific important files if they are inside ignored dirs
!data/processed/tokenizer.json
!requirements.txt

# Weights and temporary files
*.pt
*.pth
*.ckpt
*.log
error.txt

# Environment/Secrets
*.token
*.key
.env*